---
import BaseLayout from "../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="Спасибо" description="Сообщение получено." noindex>
  <section class="container-page py-20 text-center">
    <span class="badge-money">Получено</span>
    <h1 class="mt-3">Спасибо!</h1>
    <p class="mt-4 max-w-prose text-lg text-ink-muted">
      Если вы оставили заявку или подписались на чек‑лист, в течение нескольких минут письмо будет у вас на e‑mail.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a class="btn-primary" href={`${base}/`}>На главную</a>
      <a class="btn-ghost" href={`${base}/blog/`}>Почитать блог</a>
    </div>
  </section>
</BaseLayout>
