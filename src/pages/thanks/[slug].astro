---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PatternBg from "../../components/PatternBg.astro";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const data = entry.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title={`Спасибо за покупку: ${data.title}`} description="Ссылка на скачивание продукта." noindex>
  <section class="container-page pt-12 md:pt-16">
    <span class="badge-money">Оплата прошла</span>
    <h1 class="mt-3">Спасибо! Файл уже у вас.</h1>
    <p class="mt-4 max-w-prose text-lg text-ink-muted">
      Ссылка на скачивание ушла на ваш e‑mail. Если письма нет за 5 минут — проверьте «Спам»
      или напишите нам на странице контактов.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-12">
      <div class="md:col-span-7">
        <PatternBg pattern={data.pattern}>
          <span class="badge bg-black/5">{data.format}</span>
          <div class="mt-auto font-display text-3xl font-extrabold">{data.title}</div>
        </PatternBg>

        <a
          href={data.downloadUrl ?? "#"}
          class="btn-money mt-6 w-full"
          data-product={entry.slug}
        >
          {data.downloadUrl ? "Скачать сейчас" : "Ссылка отправлена на e‑mail"}
        </a>
      </div>

      <div class="md:col-span-5 space-y-4">
        <div class="rounded-card border border-ink/10 p-6">
          <h3>Что дальше</h3>
          <ol class="mt-4 list-decimal pl-5 text-sm text-ink-muted">
            <li>Откройте файл и выполните первый шаг из инструкции.</li>
            <li>Если что‑то непонятно — напишите нам на почту.</li>
            <li>Через 7 дней мы пришлём чек‑лист «как внедрили» — заполните и получите бонус.</li>
          </ol>
        </div>
        <div class="rounded-card bg-pattern-lime p-6">
          <h3>Поддержка</h3>
          <p class="mt-2 text-sm">Если возник вопрос по материалу, напишите нам на почту со страницы контактов.</p>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a class="btn-ghost" href={`${base}/marketplace/catalog/`}>Ещё для маркетплейсов</a>
      <a class="btn-ghost" href={`${base}/services/catalog/`}>Ещё для услуг</a>
    </div>
  </section>
</BaseLayout>
