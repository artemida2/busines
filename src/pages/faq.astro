---
import BaseLayout from "../layouts/BaseLayout.astro";

const items = [
  {
    q: "Как происходит оплата?",
    a: "Через ЮKassa: банковская карта, СБП или SberPay. После оплаты файл приходит на e‑mail.",
  },
  {
    q: "Как получу файл после оплаты?",
    a: "Сразу после успешной оплаты вы попадёте на страницу «Спасибо» со ссылкой на скачивание. Параллельно ту же ссылку вышлем вам на e‑mail. Если письмо не пришло за 5 минут — проверьте «Спам» или напишите нам.",
  },
  {
    q: "В каком формате продукты?",
    a: "PDF, Excel/Google Sheets, Notion‑шаблон или короткое видео — формат указан в карточке каждого продукта.",
  },
  {
    q: "Можно ли вернуть деньги?",
    a: "Да, в течение 7 дней с момента оплаты, если файл не открылся, не пришёл или не соответствует описанию. Условия — в публичной оферте.",
  },
  {
    q: "Делаете ли вы кастомные продукты под заказ?",
    a: "Да, под запрос — напишите на странице контактов с описанием задачи.",
  },
  {
    q: "Можно ли распространять купленные материалы?",
    a: "Нет, материалы предназначены для личного использования. Перепродажа и публикация без согласия запрещены — детали в оферте.",
  },
  {
    q: "У меня старый файл — обновления входят?",
    a: "Да, в течение 12 месяцев после покупки получаете обновления продукта бесплатно по той же ссылке.",
  },
];
---

<BaseLayout title="Частые вопросы" description="Оплата, доставка, формат, возврат — собрали ответы на самые частые вопросы.">
  <section class="container-page pt-12 md:pt-16">
    <span class="badge">FAQ</span>
    <h1 class="mt-3">Частые вопросы</h1>
    <p class="mt-4 text-lg text-ink-muted">
      Если ответа на ваш вопрос нет — напишите на странице контактов, обычно отвечаем в течение 24 часов.
    </p>

    <div class="mt-10 divide-y divide-ink/10 rounded-card border border-ink/10">
      {items.map((it, i) => (
        <details class="group p-5 md:p-6" {...(i === 0 ? { open: true } : {})}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
            <span class="font-display text-lg font-bold">{it.q}</span>
            <span class="font-mono text-ink-muted transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 text-ink-muted">{it.a}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
