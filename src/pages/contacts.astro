---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";
---

<BaseLayout title="Контакты" description="Связаться с нами по e‑mail.">
  <section class="container-page pt-12 md:pt-16">
    <span class="badge">Контакты</span>
    <h1 class="mt-3">Напишите нам</h1>
    <p class="mt-4 text-lg text-ink-muted">
      Единственный официальный контакт магазина — почта. Отвечаем в рабочие дни в течение 24 часов.
    </p>

    <div class="mt-10">
      <a href={`mailto:${SITE.email}`} class="block rounded-card border border-ink/10 p-6 transition hover:-translate-y-0.5 hover:shadow-card">
        <div class="font-mono text-xs uppercase tracking-widest text-ink-muted">E‑mail</div>
        <div class="mt-2 break-words font-display text-2xl font-extrabold">{SITE.email}</div>
        <div class="mt-2 text-sm text-ink-muted">По вопросам продуктов, оплаты, доступа и возвратов.</div>
      </a>
    </div>
  </section>
</BaseLayout>
