---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PatternBg from "../../components/PatternBg.astro";
import ProductCard from "../../components/ProductCard.astro";
import PaymentForm from "../../components/PaymentForm.astro";
import { formatPrice, TRACKS } from "../../lib/site";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const trackTitle = TRACKS[data.track].title;
const trackHref = `${base}/${TRACKS[data.track].slug}/`;
const previewHref = data.previewUrl ? `${base}${data.previewUrl}` : "";

const others = (
  await getCollection("products", ({ data: d, slug }) => d.track === data.track && slug !== entry.slug)
)
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 3);
---

<BaseLayout title={data.title} description={data.summary}>
  <!-- Hero карточки -->
  <section class="container-wide pt-10 md:pt-16">
    <nav class="mb-6 flex items-center gap-2 text-xs text-ink-muted">
      <a class="hover:text-brand" href={`${base}/`}>Главная</a>
      <span>/</span>
      <a class="hover:text-brand" href={trackHref}>{trackTitle}</a>
      <span>/</span>
      <span class="truncate">{data.title}</span>
    </nav>

    <div class="grid gap-8 md:grid-cols-12">
      <div class="md:col-span-7">
        <span class="badge">{trackTitle}</span>
        <h1 class="mt-3">{data.title}</h1>
        <p class="mt-4 max-w-prose text-lg text-ink-muted">{data.summary}</p>

        {data.bullets.length > 0 && (
          <ul class="mt-8 grid gap-3 sm:grid-cols-2">
            {data.bullets.map((b: string) => (
              <li class="flex gap-3 rounded-2xl border border-ink/10 p-4">
                <span class="font-mono text-brand">→</span>
                <span class="text-sm">{b}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <aside class="md:col-span-5">
        <div class="sticky top-24 space-y-4">
          <PatternBg pattern={data.pattern} class="!min-h-[200px]">
            <div class="flex items-center justify-between">
              <span class="badge bg-black/5">{data.format}</span>
              {data.pages && <span class="badge bg-black/5">{data.pages} стр.</span>}
            </div>
            <div class="mt-auto">
              <div class="font-display text-3xl font-extrabold leading-tight">
                {data.title}
              </div>
            </div>
          </PatternBg>

          <div class="rounded-card border border-ink/10 bg-paper p-6 shadow-card">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-3xl font-extrabold">{formatPrice(data.price)}</span>
              {data.oldPrice && (
                <span class="font-mono text-lg text-ink-muted line-through">{formatPrice(data.oldPrice)}</span>
              )}
            </div>
            <div class="mt-4">
              <PaymentForm slug={entry.slug} price={data.price} title={data.title} />
            </div>
            <a href={`${base}/faq/`} class="mt-3 block text-center text-xs text-ink-muted hover:text-brand">
              Как происходит оплата и доставка?
            </a>
          </div>

          <div class="rounded-2xl border border-ink/10 p-5 text-sm text-ink-muted">
            <div class="font-display font-bold text-ink">Гарантия возврата</div>
            Если файл не открылся, не пришёл или оказался не тем, что описан — вернём деньги в течение 7 дней. Условия — в публичной оферте.
          </div>
        </div>
      </aside>
    </div>
  </section>

  {data.previewUrl && (
    <section class="container-wide py-12 md:py-16">
      <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="badge">PDF preview</span>
          <h2 class="mt-3">Предпросмотр продукта</h2>
          <p class="mt-2 max-w-2xl text-ink-muted">
            Откройте первые страницы перед покупкой: так видно структуру, стиль и уровень детализации материала.
          </p>
        </div>
        <a class="btn-ghost" href={previewHref} target="_blank" rel="noopener">
          Открыть PDF →
        </a>
      </div>
      <div class="overflow-hidden rounded-card border border-ink/10 bg-paper shadow-card">
        <iframe
          class="h-[520px] w-full bg-white md:h-[720px]"
          src={previewHref}
          title={`Предпросмотр: ${data.title}`}
        ></iframe>
      </div>
    </section>
  )}

  <!-- Кому подойдёт / что внутри -->
  <section class="container-wide py-12 md:py-16">
    <div class="grid gap-8 md:grid-cols-2">
      {data.forWhom.length > 0 && (
        <div class="rounded-card bg-paper-tint p-6 md:p-8">
          <h3>Кому подойдёт</h3>
          <ul class="mt-4 space-y-2 text-ink">
            {data.forWhom.map((x: string) => (
              <li class="flex gap-2"><span class="text-brand">·</span><span>{x}</span></li>
            ))}
          </ul>
        </div>
      )}
      {data.inside.length > 0 && (
        <div class="rounded-card bg-paper-tint p-6 md:p-8">
          <h3>Что внутри</h3>
          <ul class="mt-4 space-y-2 text-ink">
            {data.inside.map((x: string) => (
              <li class="flex gap-2"><span class="text-money">·</span><span>{x}</span></li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <!-- Описание (mdx/markdown) -->
  <section class="container-page pb-12 md:pb-16">
    <article class="prose-editorial">
      <Content />
    </article>
  </section>

  <!-- Похожие -->
  {others.length > 0 && (
    <section class="container-wide py-8 md:py-16">
      <div class="mb-6 flex items-end justify-between">
        <h2>Похожие в этом направлении</h2>
        <a class="btn-ghost hidden md:inline-flex" href={trackHref}>Все продукты →</a>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {others.map((p) => <ProductCard product={p} />)}
      </div>
    </section>
  )}
</BaseLayout>
