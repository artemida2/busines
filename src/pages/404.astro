---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="404 — страница не найдена" description="Такой страницы нет.">
  <section class="container-page py-20 text-center">
    <span class="badge">404</span>
    <h1 class="mt-3">Страницы нет</h1>
    <p class="mt-4 max-w-prose mx-auto text-lg text-ink-muted">
      Возможно, вы перешли по старой ссылке. Откройте каталог или начните с главной.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a class="btn-primary" href={`${base}/`}>На главную</a>
      <a class="btn-ghost" href={`${base}/marketplace/catalog/`}>Каталог</a>
    </div>
  </section>
</BaseLayout>
