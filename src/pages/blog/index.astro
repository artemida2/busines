---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));

const tracks = [
  { key: "all", label: "Все" },
  { key: "marketplace", label: "Маркетплейсы" },
  { key: "services", label: "Самозанятые" },
  { key: "general", label: "Общее" },
] as const;
---

<BaseLayout title="Блог" description="Разборы, чек‑листы и новости про маркетплейсы и самозанятых.">
  <section class="container-wide pt-12 md:pt-16">
    <span class="badge">Блог</span>
    <h1 class="mt-3">Что почитать</h1>
    <p class="mt-4 max-w-2xl text-ink-muted">
      Длинные разборы и короткие конспекты — о юнит‑экономике, налогах, кейсах продавцов
      и работе с клиентами. Без воды.
    </p>
  </section>

  <section class="container-wide py-10">
    <div class="flex flex-wrap gap-2">
      {tracks.map((t) => (
        <button class="badge bg-ink/5 hover:bg-ink hover:text-paper transition-colors" data-filter={t.key}>{t.label}</button>
      ))}
    </div>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((p) => (
        <div data-track={p.data.track}>
          <BlogCard post={p} />
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll("[data-filter]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter");
        document.querySelectorAll("[data-track]").forEach((card) => {
          const t = card.getAttribute("data-track");
          card.style.display = (f === "all" || t === f) ? "" : "none";
        });
      });
    });
  </script>
</BaseLayout>
