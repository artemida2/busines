---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Calculator from "../../components/Calculator.astro";
import { commissions } from "../../lib/calc";
import type { MarketplaceSlug } from "../../lib/calc";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const mps = (Object.entries(commissions.marketplaces) as [
  MarketplaceSlug,
  (typeof commissions.marketplaces)[MarketplaceSlug]
][]).map(([key, m]) => ({ ...m, slug: key }));

const title = "Калькулятор юнит‑экономики WB и Ozon — бесплатно";
const description =
  "Считаем чистую прибыль с одной единицы, точку безубыточности, безопасную цену в акции и 5 светофоров по марже, логистике, возвратам, оборачиваемости. Актуальные комиссии WB и Ozon на 2026 год.";
---

<BaseLayout title={title} description={description}>
  <section class="container-page py-10 md:py-14">
    <div class="mb-8 max-w-3xl">
      <span class="badge badge-brand">Бесплатно · Без регистрации</span>
      <h1 class="mt-3 font-display text-4xl font-extrabold leading-[1.05] md:text-6xl">
        Калькулятор юнит‑экономики <span class="bg-pattern-lime px-2">WB и Ozon</span>
      </h1>
      <p class="mt-4 text-lg text-ink-soft">
        Считаем не только маржу, но и <strong>точку безубыточности</strong>, минимальную цену в акции
        и пять «светофоров»: маржа, логистика, возвраты, акции и оборачиваемость. Со встроенными
        ставками по {Object.values(commissions.marketplaces).reduce((s, m) => s + Object.keys(m.categories).length, 0)} категориям WB и Ozon.
      </p>
    </div>

    <Calculator />

    <!-- Категории-лендинги -->
    <div id="categories" class="mt-14 space-y-10">
      {mps.map((mp) => (
        <div>
          <div class="mb-4 flex items-end justify-between gap-3">
            <h2 class="font-display text-2xl font-extrabold md:text-3xl">
              Категории {mp.name}
            </h2>
            <span class="text-xs font-mono text-ink-muted">
              {Object.keys(mp.categories).length} разделов
            </span>
          </div>
          <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            {Object.entries(mp.categories).map(([slug, c]) => (
              <a
                href={`${base}/calc/${mp.slug}/${slug}/`}
                class="group flex items-center justify-between gap-3 rounded-card border border-ink/10 bg-paper-tint p-3 transition-colors hover:border-brand"
              >
                <div>
                  <div class="font-display text-base font-bold">{c.name}</div>
                  <div class="text-xs text-ink-muted">
                    Комиссия {c.commission}% · возвраты {c.returnRate}%
                  </div>
                </div>
                <span class="font-mono text-xs text-ink-muted group-hover:text-brand">→</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Источник ставок -->
    <div class="mt-12 max-w-3xl text-sm text-ink-muted">
      <h2 class="font-display text-xl font-bold text-ink">Откуда берём ставки</h2>
      <p class="mt-3">
        Комиссии и тарифы хранятся в JSON‑справочнике в репозитории сайта и обновляются вручную
        при изменениях со стороны WB / Ozon. Версия данных:
        <strong>{commissions.version}</strong>, последнее обновление —
        <strong>{commissions.lastUpdated}</strong>. Источники — публичные тарифы маркетплейсов и
        информация из личных кабинетов поставщиков. Калькулятор даёт <em>ориентир</em>, не финальный
        финплан: всегда сверяйтесь с актуальными ставками в кабинете перед запуском SKU.
      </p>
    </div>
  </section>
</BaseLayout>
