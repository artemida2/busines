---
import type { CollectionEntry } from "astro:content";
import PatternBg from "./PatternBg.astro";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { data, slug } = post;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = `${base}/blog/${slug}/`;

const trackLabel = {
  marketplace: "Маркетплейсы",
  services: "Самозанятые",
  general: "Общее",
}[data.track];

const date = new Date(data.publishedAt).toLocaleDateString("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<a href={href} class="group block focus:outline-none">
  <PatternBg pattern={data.pattern} class="group-hover:shadow-card">
    <div class="flex items-center justify-between gap-3">
      <span class="badge bg-black/5 backdrop-blur">{trackLabel}</span>
      <time class="font-mono text-xs opacity-70">{date}</time>
    </div>

    <div class="mt-6">
      <h3 class="font-display text-2xl font-extrabold leading-[1.15] md:text-3xl">
        {data.title}
      </h3>
      <p class="mt-3 text-sm/relaxed opacity-80">
        {data.summary}
      </p>
    </div>

    <div class="mt-6 flex items-center justify-between">
      <span class="text-sm font-medium">Читать →</span>
      {data.tags?.length ? (
        <div class="flex flex-wrap gap-1">
          {data.tags.slice(0, 2).map((t: string) => (
            <span class="badge bg-black/5 text-xs">#{t}</span>
          ))}
        </div>
      ) : null}
    </div>
  </PatternBg>
</a>
