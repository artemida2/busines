---
import { formatPrice } from "../lib/site";
import type { CollectionEntry } from "astro:content";
import PatternBg from "./PatternBg.astro";

export interface Props {
  product: CollectionEntry<"products">;
}

const { product } = Astro.props;
const { data, slug } = product;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = `${base}/products/${slug}/`;

const trackLabel = data.track === "marketplace" ? "Маркетплейсы" : "Самозанятые / ИП";
---

<a href={href} class="group block focus:outline-none">
  <PatternBg pattern={data.pattern} class="group-hover:shadow-card">
    <div class="flex items-center justify-between gap-3">
      <span class="badge bg-black/5 backdrop-blur">{trackLabel}</span>
      <span class="badge bg-black/5 backdrop-blur">{data.format}</span>
    </div>

    <div class="mt-6">
      <h3 class="font-display text-2xl font-extrabold leading-[1.1] md:text-3xl">
        {data.title}
      </h3>
      <p class="mt-3 text-sm/relaxed opacity-80">
        {data.summary}
      </p>
    </div>

    <div class="mt-6 flex items-end justify-between gap-3">
      <div>
        <div class="font-mono text-2xl font-bold tracking-tight">
          {formatPrice(data.price)}
        </div>
        {data.oldPrice && (
          <div class="font-mono text-sm line-through opacity-60">
            {formatPrice(data.oldPrice)}
          </div>
        )}
      </div>
      <span class="arrow-pill">→</span>
    </div>
  </PatternBg>
</a>
